generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────
// Enums
// ──────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum WillStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  NEEDS_REVISION
  COMPLETED
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
  DOMESTIC_PARTNERSHIP
}

enum ConsultationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentType {
  WILL_BASIC
  ATTORNEY_REVIEW
  CONSULTATION
  NOTARIZATION
}

// ──────────────────────────────────────────
// NextAuth Required Models
// ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────
// Core Models
// ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  willDocuments WillDocument[]
  consultations Consultation[]
  payments      Payment[]
}

model WillDocument {
  id          String     @id @default(cuid())
  userId      String
  status      WillStatus @default(DRAFT)
  currentStep Int        @default(1)

  // US State for jurisdiction-aware compliance
  state       String?

  // Each step stores its data as JSON — avoids premature normalization in MVP
  // and allows partial saves without nullable FK complexity
  personalInfo   Json? // PersonalInfoData
  executorInfo   Json? // ExecutorInfoData
  beneficiaries  Json? // BeneficiaryData[]
  guardianship   Json? // GuardianshipData
  assetsOverview Json? // AssetData[]

  // Admin & attorney fields
  adminNotes  String?  @db.Text
  pdfUrl      String?

  submittedAt DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  attorneyReviewRequest AttorneyReviewRequest?
  payments              Payment[]

  @@index([userId])
  @@index([status])
}

model AttorneyReviewRequest {
  id             String     @id @default(cuid())
  willDocumentId String     @unique
  status         WillStatus @default(SUBMITTED)
  requestedAt    DateTime   @default(now())
  completedAt    DateTime?
  attorneyNotes  String?    @db.Text
  reviewedBy     String?    // Admin User.id

  willDocument WillDocument @relation(fields: [willDocumentId], references: [id], onDelete: Cascade)
}

model Consultation {
  id          String             @id @default(cuid())
  userId      String
  scheduledAt DateTime
  duration    Int                @default(60) // minutes
  status      ConsultationStatus @default(PENDING)
  notes       String?            @db.Text
  meetingUrl  String?
  timezone    String             @default("America/New_York")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment Payment?

  @@index([userId])
  @@index([scheduledAt])
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  type            PaymentType
  status          PaymentStatus @default(PENDING)
  amount          Int // in cents
  currency        String        @default("usd")
  stripeSessionId String?       @unique
  stripePaymentId String?       @unique

  willDocumentId String?
  consultationId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  willDocument WillDocument? @relation(fields: [willDocumentId], references: [id])
  consultation Consultation? @relation(fields: [consultationId], references: [id])

  @@index([userId])
  @@index([stripeSessionId])
  @@index([status])
}
