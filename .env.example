# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/legadoclaro?schema=public"

# ──────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — create at console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ──────────────────────────────────────────
# Stripe
# ──────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_WILL_BASIC="price_..."          # $99
STRIPE_PRICE_ATTORNEY_REVIEW="price_..."     # $249
STRIPE_PRICE_CONSULTATION="price_..."        # $199
STRIPE_PRICE_NOTARIZATION="price_..."        # $79

# ──────────────────────────────────────────
# Resend (Email)
# ──────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="LegadoClaro <noreply@legadoclaro.com>"

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
